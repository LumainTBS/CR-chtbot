# ── Code Red Solutions Chatbot — Environment Variables ──
# Copy this file, rename it to .env, and fill in your values.
# NEVER share this file or upload it to GitHub.

# From Meta Developer Console → WhatsApp → API Setup
ACCESS_TOKEN=paste_your_meta_access_token_here
PHONE_NUMBER_ID=paste_your_phone_number_id_here

# From Meta Business Manager → Catalogue → Settings → Catalogue ID
CATALOG_ID=paste_your_catalogue_id_here

# From Google AI Studio → aistudio.google.com → Get API Key
GEMINI_API_KEY=paste_your_gemini_api_key_here
